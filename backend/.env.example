# ──── Supabase ────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ──── JWT (for Express auth) ────
JWT_SECRET=your-jwt-secret

# ──── Server ────
PORT=5000

# ──── WhatsApp Master Admin ────
# Master login bypasses all checks. Use this to create/manage users.
WHATSAPP_MASTER_EMAIL=admin@whatsapp.com
WHATSAPP_MASTER_PASSWORD=Admin123!

# ──── WhatsApp Cloud API (Meta) ────
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_API_VERSION=v23.0
WHATSAPP_WABA_ID=your-waba-id

# ──── WhatsApp Templates ────
WHATSAPP_TEMPLATE_NAME=bsct_receipt
WHATSAPP_SUPABASE_FUNCTION_URL=https://your-project.supabase.co/functions/v1/send-template
WHATSAPP_SUPABASE_API_KEY=your-supabase-api-key

# ──── Admin Seed ────
ADMIN_EMAIL=admin@ufs.com
ADMIN_PASSWORD=123456

# ──── Optional: OCR, Firebase, Groq, Razorpay, IMAP, Paytm ────
# OCR_SPACE_KEY=
# GROQ_API_KEY=
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=
# IMAP_ENABLED=false
# RAZORPAY_ENABLED=false
# PAYTM_ENABLED=false
